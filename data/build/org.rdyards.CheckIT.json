{
  "app-id": "org.rdyards.CheckIT",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable",
    "org.freedesktop.Sdk.Extension.gtk4"
  ],
  "command": "checkit",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=x11",
    "--filesystem=host"
  ],
  "modules": [
    {
      "name": "checkit",
      "buildsystem": "simple",
      "build-commands": [
        "cargo fetch --manifest-path Cargo.toml",
        "cargo build --release",
        "install -Dm755 target/release/checkit /app/bin/checkit",
        "install -Dm644 data/build/checkit.desktop /app/share/applications/checkit.desktop",
        "install -Dm644 data/build/org.rdyards.CheckIT.svg /app/share/icons/hicolor/scalable/apps/checkit.svg"
      ],
      "sources": [{ "type": "dir", "path": "." }, "cargo-sources.json"]
    }
  ]
}
