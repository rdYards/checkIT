<?xml version="1.0" encoding="UTF-8" ?>
<interface>
  <requires lib="libadwaita" version="1.0" />

  <object class="AdwApplicationWindow" id="main_window">
    <property name="default-width">800</property>
    <property name="default-height">600</property>
    <property name="content">
      <object class="AdwNavigationSplitView" id="split_view">
        <property name="min-sidebar-width">200</property>
        <property name="sidebar">
          <object class="AdwNavigationPage">
            <property name="title" translatable="yes">Network Banners</property>
            <child>
              <object class="AdwToolbarView">
                <child type="top">
                  <object class="AdwHeaderBar">
                    <property name="show-title">True</property>
                    <child type="title">
                      <object class="GtkLabel">
                        <property name="label" translatable="no">CheckIT</property>
                      </object>
                    </child>
                    <child type="start">
                      <object class="GtkToggleButton">
                        <property name="icon-name">preferences-system-search-symbolic</property>
                        <property name="tooltip-text" translatable="yes">New Collection</property>
                        <property name="action-name">win.search-collection</property>
                      </object>
                    </child>
                    <child type="end">
                      <object class="GtkToggleButton">
                        <property name="icon-name">list-add-symbolic</property>
                        <property name="tooltip-text" translatable="yes">New Collection</property>
                        <property name="action-name">win.new-collection</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child>
                  <!-- Ledger Banner Btns zone -->
                  <object class="GtkScrolledWindow">
                  <property name="hexpand">True</property>
                  <property name="vexpand">True</property>
                  <property name="min-content-height">0</property>
                    <child>
                        <object class="GtkListBox" id="ledger_banner_list">
                        <property name="selection-mode">none</property>
                        <property name="hexpand">True</property>
                        <property name="vexpand">True</property>
                        </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>

        <property name="content">
          <object class="AdwNavigationPage">
            <property name="title" translatable="yes">Collection Title</property>
            <child>
              <object class="AdwToolbarView">
                <child type="top">
                  <object class="AdwHeaderBar">
                    <property name="show-title">True</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </property>
      </object>
    </property>
    <child>
      <object class="AdwBreakpoint">
        <condition>max-width: 700sp</condition>
        <setter object="split_view" property="collapsed">True</setter>
      </object>
    </child>
  </object>
</interface>