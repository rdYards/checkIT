<?xml version="1.0" encoding="UTF-8" ?>
<interface>
    <requires lib="libadwaita" version="1.0" />

    <object class="GtkBox" id="banner_box">
        <property name="orientation">horizontal</property>
        <property name="spacing">12</property>
        <property name="halign">center</property>

        <child type="start">
            <object class="GtkImage" id="drive_icon">
                <property name="icon-name">drive-multidisk-symbolic</property>
                <property name="halign">start</property>
            </object>
        </child>

        <child>
            <object class="GtkLabel" id="network_label">
                <property name="label">Network</property>
                <property name="halign">center</property>
                <property name="hexpand">true</property>
            </object>
        </child>

        <child type="end">
            <object class="GtkButton" id="lock_btn">
                <child>
                    <style>
                        <class name="lock-button"/>
                    </style>
                    <object class="GtkImage" id="lock_icon">
                        <property name="icon-name">padlock2-open-symbolic</property>
                    </object>
                </child>
                <property name="halign">end</property>
            </object>
        </child>
    </object>
</interface>